# Room Match API — environment variables
# Copy this file to `.env` and fill in real values for local dev.
# In production (Railway / Render / etc.), set these in the platform's UI.

# --- Required ---
# Standard libpq connection string. Works with Supabase, Render Postgres,
# Railway Postgres, Neon, or a local docker-compose Postgres.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/room_match

# --- Server ---
NODE_ENV=development          # development | test | production
PORT=4000                     # HTTP port (Railway injects PORT automatically)
CORS_ORIGIN=*                 # comma-separated origins in prod, e.g. https://room-match.up.railway.app
LOG_LEVEL=info                # fatal | error | warn | info | debug | trace

# --- Admin bootstrap (first boot only — no-op after first admin row exists) ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin1234

# --- Public sign-in (Google OIDC) ---
# Leave blank to keep /api/auth/google/start returning 503 — app still boots.
# Google Cloud Console: https://console.cloud.google.com/apis/credentials
# OAuth client type: Web application
# Authorized redirect URIs (must match exactly):
#   http://localhost:4000/api/auth/google/callback
#   https://room-match-api-production.up.railway.app/api/auth/google/callback
# Scopes on consent screen: openid, email, profile
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/api/auth/google/callback

# --- Admin SSO (Microsoft Entra ID / Azure AD) ---
# Leave blank to keep /api/auth/azure/start returning 503 — app still boots.
# Azure portal: App registrations → your app → Authentication
# Redirect URIs (must match exactly):
#   http://localhost:4000/api/auth/azure/callback
#   https://room-match-api-production.up.railway.app/api/auth/azure/callback
# Single-tenant: any user from this Entra ID tenant is allowed in.
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_REDIRECT_URI=http://localhost:4000/api/auth/azure/callback

# --- Cross-subdomain cookies (Railway / multi-service prod) ---
# In prod the frontend and backend live on different subdomains of the same
# eTLD+1 (e.g. *.up.railway.app). Without `Domain=` set, cookies become
# host-only and the browser won't send them across subdomains — see RFC 6265
# §5.2.3. Set COOKIE_DOMAIN to your shared parent (with leading dot).
# Leave blank in dev (same-origin via the Vite proxy → :4000).
# Examples:
#   Railway:  COOKIE_DOMAIN=.up.railway.app
#   Custom:   COOKIE_DOMAIN=.yourdomain.com
COOKIE_DOMAIN=

# --- Dev-only mock login (persona-based, bypasses OAuth) ---
# When MOCK_AUTH=true, the /api/auth/mock/login endpoint is enabled and
# exposes two personas seeded in tenants (id=1) and landlords (id=1).
# Toggle this off in production deploys — the endpoint will return 404 to
# hide its existence. When real OAuth credentials land, set this false
# permanently and the Google / Azure flows take over.
MOCK_AUTH=true
MOCK_TENANT_ID=1
MOCK_LANDLORD_ID=1
